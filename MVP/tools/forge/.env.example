# SHT Forge — copy to .env.local (gitignored) and fill what you use.
# With NOTHING set, the forge runs fully in mock mode (no keys, stand-in art).

# PORT=5174

# LLM that writes characters from your prompt: mock | ollama | anthropic
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://192.168.1.217:11434
# OLLAMA_MODEL=qwen3.5
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# PixelLab art (8-direction v3 tokens). Leave empty for mock art.
# PIXELLAB_API_KEY=
# PIXELLAB=mock          # force mock even with a key
